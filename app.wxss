/* app.wxss - 全局样式（浅色系） */
page {
  background-color: #f2f4f8;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  border: 1rpx solid #e4e8f0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #1976d2, #1565c0);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(25, 118, 210, 0.35);
}

.btn-success {
  background: linear-gradient(135deg, #388e3c, #2e7d32);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(56, 142, 60, 0.35);
}

.btn-danger {
  background: linear-gradient(135deg, #e53935, #c62828);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(229, 57, 53, 0.3);
}

.btn-outline {
  background: transparent;
  color: #1976d2;
  border: 2rpx solid #1976d2;
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 32rpx;
  border-radius: 10rpx;
}

/* 标签 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge-blue {
  background: rgba(25, 118, 210, 0.1);
  color: #1565c0;
  border: 1rpx solid rgba(25, 118, 210, 0.25);
}

.badge-green {
  background: rgba(56, 142, 60, 0.1);
  color: #2e7d32;
  border: 1rpx solid rgba(56, 142, 60, 0.25);
}

.badge-red {
  background: rgba(229, 57, 53, 0.1);
  color: #c62828;
  border: 1rpx solid rgba(229, 57, 53, 0.25);
}

.badge-gray {
  background: rgba(100, 100, 120, 0.1);
  color: #666;
  border: 1rpx solid rgba(100, 100, 120, 0.2);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e8ecf2;
  margin: 16rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-state text {
  margin-top: 16rpx;
  font-size: 28rpx;
}

/* 加载动画 */
.loading-dot {
  display: inline-block;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* 行布局 */
.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 颜色 */
.text-blue  { color: #1565c0; }
.text-green { color: #2e7d32; }
.text-red   { color: #c62828; }
.text-yellow{ color: #f57f17; }
.text-gray  { color: #888; }
.text-white { color: #1a1a2e; }

.text-sm   { font-size: 22rpx; }
.text-xs   { font-size: 20rpx; }
.text-bold { font-weight: 600; }
.text-mono { font-family: 'Courier New', monospace; }
