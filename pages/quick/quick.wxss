/* pages/quick/quick.wxss */
.container {
  min-height: 100vh;
  background: #f2f4f8;
  display: flex;
  flex-direction: column;
}

/* ===== 连接状态栏 ===== */
.conn-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e4e8f0;
}

.conn-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-green { background: #43a047; box-shadow: 0 0 8rpx rgba(67,160,71,0.5); }
.dot-gray  { background: #ccc; }

.conn-label {
  font-size: 24rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  background: #1976d2;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.add-btn:active { opacity: 0.8; }

.add-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 空状态 ===== */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 8rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #555;
}

.empty-desc {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.8;
}

.empty-add-btn {
  margin-top: 16rpx;
  padding: 18rpx 48rpx;
  background: #1976d2;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-add-btn:active { opacity: 0.8; }

/* ===== 操作列表 ===== */
.action-list {
  flex: 1;
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
}

/* ===== 操作卡片 ===== */
.action-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid #e4e8f0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

/* 各色系卡片头部条 */
.action-card-blue   { border-top: 6rpx solid #1976d2; }
.action-card-green  { border-top: 6rpx solid #388e3c; }
.action-card-orange { border-top: 6rpx solid #f57c00; }
.action-card-red    { border-top: 6rpx solid #e53935; }
.action-card-purple { border-top: 6rpx solid #8e24aa; }
.action-card-teal   { border-top: 6rpx solid #00897b; }

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 12rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.card-color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-blue   { background: #1976d2; }
.dot-green  { background: #388e3c; }
.dot-orange { background: #f57c00; }
.dot-red    { background: #e53935; }
.dot-purple { background: #8e24aa; }
.dot-teal   { background: #00897b; }

.card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-menu {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.card-menu-btn {
  font-size: 36rpx;
  color: #bbb;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
}

.card-menu-btn:active { background: #f2f4f8; }

.card-del-btn:active { color: #e53935; }

/* 卡片信息行 */
.card-info {
  padding: 0 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.info-label {
  font-size: 20rpx;
  color: #aaa;
  width: 44rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.info-value {
  font-size: 20rpx;
  color: #555;
  flex: 1;
  word-break: break-all;
  line-height: 1.5;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  flex-wrap: wrap;
}

.type-badge {
  font-size: 17rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  flex-shrink: 0;
}

.type-badge-hex  { color: #1565c0; background: rgba(25,118,210,0.1); border: 1rpx solid rgba(25,118,210,0.2); }
.type-badge-text { color: #2e7d32; background: rgba(46,125,50,0.1);  border: 1rpx solid rgba(46,125,50,0.2); }

/* ===== 执行按钮 ===== */
.exec-btn {
  margin: 0 24rpx 24rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  transition: opacity 0.15s;
}

.exec-btn:active { opacity: 0.8; }

/* 各色系执行按钮 */
.exec-btn-color-blue   { background: linear-gradient(135deg, #1976d2, #1565c0); color: #fff; box-shadow: 0 4rpx 16rpx rgba(25,118,210,0.35); }
.exec-btn-color-green  { background: linear-gradient(135deg, #388e3c, #2e7d32); color: #fff; box-shadow: 0 4rpx 16rpx rgba(56,142,60,0.35); }
.exec-btn-color-orange { background: linear-gradient(135deg, #f57c00, #e65100); color: #fff; box-shadow: 0 4rpx 16rpx rgba(245,124,0,0.35); }
.exec-btn-color-red    { background: linear-gradient(135deg, #e53935, #c62828); color: #fff; box-shadow: 0 4rpx 16rpx rgba(229,57,53,0.3); }
.exec-btn-color-purple { background: linear-gradient(135deg, #8e24aa, #7b1fa2); color: #fff; box-shadow: 0 4rpx 16rpx rgba(142,36,170,0.3); }
.exec-btn-color-teal   { background: linear-gradient(135deg, #00897b, #00695c); color: #fff; box-shadow: 0 4rpx 16rpx rgba(0,137,123,0.3); }

/* 执行中：降低不透明度 */
.exec-btn-running { opacity: 0.65; }

/* 成功：绿色覆盖 */
.exec-btn-ok {
  background: linear-gradient(135deg, #43a047, #2e7d32) !important;
  box-shadow: 0 4rpx 16rpx rgba(67,160,71,0.35) !important;
}

/* 失败：红色覆盖 */
.exec-btn-err {
  background: linear-gradient(135deg, #e53935, #c62828) !important;
  box-shadow: 0 4rpx 16rpx rgba(229,57,53,0.3) !important;
}

.exec-loading {
  display: inline-block;
  animation: spin 0.8s linear infinite;
}

.exec-hint-text {
  font-size: 22rpx;
  opacity: 0.85;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ===== 编辑面板 ===== */
.editor-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.editor-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 101;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}

.editor-panel-show {
  transform: translateY(0);
}

.editor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f3f9;
  flex-shrink: 0;
}

.editor-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.editor-close {
  font-size: 28rpx;
  color: #bbb;
  padding: 4rpx 8rpx;
}

.editor-close:active { color: #555; }

.editor-body {
  flex: 1;
  padding: 24rpx 32rpx 0;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

/* 表单组 */
.field-group {
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.field-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 10rpx;
  display: block;
  overflow: hidden;
}

.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  min-width: 0;
}

.field-optional {
  font-size: 20rpx;
  color: #bbb;
  font-weight: 400;
}

.required {
  color: #e53935;
}

.field-fill-btn {
  font-size: 22rpx;
  color: #1976d2;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(25,118,210,0.4);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.field-fill-btn:active { opacity: 0.7; }

.field-input {
  display: block;
  width: 100%;
  height: 72rpx;
  background: #f7f9fc;
  border: 1rpx solid #e0e4ee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #1a1a2e;
  max-width: 100%;
}

/* 写入类型切换 */
.type-switch {
  display: flex;
  background: #f2f4f8;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e0e4ee;
}

.type-btn {
  padding: 6rpx 22rpx;
  font-size: 22rpx;
  color: #aaa;
}

.type-active {
  background: rgba(25, 118, 210, 0.1);
  color: #1565c0;
  font-weight: 600;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.color-option {
  width: 88rpx;
  height: 64rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  position: relative;
}

.color-option:active { opacity: 0.8; }

.color-option-selected {
  border-width: 3rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.color-check {
  font-size: 18rpx;
  font-weight: 700;
}

/* 底部操作栏 */
.editor-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 48rpx;
  border-top: 1rpx solid #f0f3f9;
  flex-shrink: 0;
}

.editor-cancel-btn {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
}

.editor-save-btn {
  flex: 2;
  height: 88rpx;
  font-size: 28rpx;
}
