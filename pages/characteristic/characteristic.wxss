/* pages/characteristic/characteristic.wxss（浅色系） */
.container {
  min-height: 100vh;
  background: #f2f4f8;
  padding-bottom: 40rpx;
}

/* UUID 卡片 */
.uuid-card {
  background: #ffffff;
  margin: 20rpx 20rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e8f0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.uuid-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.copy-btn {
  padding: 4rpx 16rpx;
  border: 1rpx solid rgba(25, 118, 210, 0.35);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1976d2;
}

.uuid-text {
  font-size: 22rpx;
  color: #555;
  word-break: break-all;
  line-height: 1.6;
}

.uuid-row-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

/* 属性标签行 + 快捷入口 */
.props-footer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* 属性标签 */
.props-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

/* 快捷操作入口按钮 */
.quick-add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(21, 101, 192, 0.08);
  border: 1rpx solid rgba(25, 118, 210, 0.3);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.quick-add-btn:active {
  opacity: 0.7;
  background: rgba(21, 101, 192, 0.15);
}

.quick-add-icon {
  font-size: 22rpx;
}

.quick-add-text {
  font-size: 22rpx;
  color: #1565c0;
  font-weight: 600;
}

.prop-chip {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.prop-read {
  color: #1565c0;
  background: rgba(25, 118, 210, 0.08);
  border: 1rpx solid rgba(25, 118, 210, 0.22);
}

.prop-write {
  color: #2e7d32;
  background: rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.22);
}

.prop-notify {
  color: #e65100;
  background: rgba(230, 81, 0, 0.08);
  border: 1rpx solid rgba(230, 81, 0, 0.22);
}

/* 功能卡片 */
.section-card {
  background: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e8f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 读取结果 */
.result-box {
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e4e8f0;
}

.result-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.result-row:last-child {
  margin-bottom: 0;
}

.result-label {
  flex-shrink: 0;
  width: 60rpx;
  padding-top: 2rpx;
}

.result-value {
  flex: 1;
  word-break: break-all;
  line-height: 1.6;
  color: #333;
}

.empty-result {
  padding: 20rpx 0 4rpx;
  text-align: center;
}

/* 写入区域 */
.type-switch {
  display: flex;
  background: #f2f4f8;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e0e4ee;
}

.type-btn {
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  color: #aaa;
  transition: all 0.2s;
}

.type-active {
  background: rgba(25, 118, 210, 0.1);
  color: #1565c0;
  font-weight: 600;
}

.input-row {
  background: #f7f9fc;
  border-radius: 12rpx;
  border: 1rpx solid #e0e4ee;
  overflow: hidden;
}

.write-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  box-sizing: border-box;
  color: #2e7d32;
  font-size: 26rpx;
  background: transparent;
  line-height: 1.6;
}

/* 写入操作行 */
.write-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  gap: 12rpx;
}

.btn-send {
  min-width: 140rpx;
}

/* 预设「保存」按钮：更小更轻量，宽度自适应内容 */
.btn-preset-save {
  width: auto !important;
  height: 52rpx !important;
  font-size: 22rpx !important;
  padding: 0 20rpx !important;
  border-radius: 10rpx !important;
  font-weight: 500 !important;
  box-shadow: none !important;
  color: #1976d2;
  border: 1rpx solid rgba(25, 118, 210, 0.5);
  background: rgba(25, 118, 210, 0.06);
}

/* 预设切换按钮 */
.preset-toggle-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #f2f4f8;
  border: 1rpx solid #e0e4ee;
}

.preset-toggle-btn:active { opacity: 0.7; }

.preset-toggle-icon {
  font-size: 18rpx;
  color: #999;
}

.preset-toggle-text {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

/* 预设面板 */
.preset-panel {
  margin-top: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e8ecf5;
  background: #f7f9fc;
  overflow: hidden;
}

.preset-empty {
  padding: 24rpx 20rpx;
  text-align: center;
}

.preset-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #edf0f7;
  gap: 12rpx;
}

.preset-item:last-child {
  border-bottom: none;
}

/* 整行点击态只在左侧内容区触发，见 preset-item-left */

.preset-item-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.preset-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preset-value {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #999;
}

.preset-item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.preset-type-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 3rpx 12rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
}

.badge-hex {
  color: #1565c0;
  background: rgba(25, 118, 210, 0.1);
  border: 1rpx solid rgba(25, 118, 210, 0.2);
}

.badge-text {
  color: #2e7d32;
  background: rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.2);
}

/* 编辑按钮图标 */
.preset-edit-btn {
  font-size: 26rpx;
  color: #bbb;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

.preset-edit-btn:active {
  color: #1976d2;
  background: rgba(25, 118, 210, 0.08);
}

/* 内联编辑态整行背景 */
.preset-item-editing {
  background: #f0f5ff;
  border-left: 3rpx solid #1976d2;
}

/* 内联编辑容器 */
.preset-edit-inline {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 4rpx 0;
}

.preset-edit-fields {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.preset-edit-field {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff;
  border: 1rpx solid #d0d8ee;
  border-radius: 10rpx;
  padding: 0 16rpx;
  height: 60rpx;
}

.preset-edit-field-label {
  font-size: 20rpx;
  color: #aaa;
  flex-shrink: 0;
  width: 44rpx;
}

.preset-edit-input {
  flex: 1;
  font-size: 24rpx;
  color: #1a1a2e;
  height: 60rpx;
  line-height: 60rpx;
  background: transparent;
}

.preset-edit-input-value {
  color: #1565c0;
}

/* 确认/取消操作行 */
.preset-edit-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.preset-edit-cancel {
  font-size: 24rpx;
  color: #aaa;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e4ee;
  background: #f5f6fa;
}

.preset-edit-cancel:active {
  opacity: 0.7;
}

.preset-edit-confirm {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  padding: 6rpx 24rpx;
  border-radius: 8rpx;
  background: #1976d2;
}

.preset-edit-confirm:active {
  opacity: 0.8;
}

.preset-del {
  font-size: 26rpx;
  color: #ccc;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

.preset-del:active {
  color: #e53935;
  background: rgba(229, 57, 53, 0.08);
}

/* Notify 区域 */
.notify-status-inline {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: rgba(56, 142, 60, 0.07);
  border-radius: 20rpx;
}

.notify-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f3f9;
}

.notify-clear-btn {
  padding: 8rpx 16rpx;
  color: #aaa;
}

.notify-toggle-btn {
  min-width: 160rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.dot-green {
  background: #43a047;
  box-shadow: 0 0 8rpx rgba(67, 160, 71, 0.5);
  animation: pulse-dot 1.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.notify-list {
  max-height: 480rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
  border: 1rpx solid #e4e8f0;
}

.notify-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 14rpx 20rpx;
  border-bottom: 1rpx solid #edf0f7;
}

.notify-item:last-child {
  border-bottom: none;
}

.notify-time {
  flex-shrink: 0;
  color: #bbb;
  font-size: 20rpx;
  font-family: 'Courier New', monospace;
  padding-top: 2rpx;
}

.notify-hex {
  flex: 1;
  word-break: break-all;
  line-height: 1.6;
  font-size: 22rpx;
  color: #333;
}

/* ======== 日志面板 ======== */
.log-panel {
  margin: 16rpx 20rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #e4e8f0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.log-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  background: #faf6ff;
  border-bottom: 1rpx solid #ede8f5;
}

.log-panel-header:active { opacity: 0.8; }

.log-panel-icon { font-size: 26rpx; }

.log-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #7b1fa2;
}

.log-count-badge {
  background: rgba(123,31,162,0.1);
  border: 1rpx solid rgba(123,31,162,0.25);
  border-radius: 20rpx;
  padding: 2rpx 14rpx;
  font-size: 20rpx;
  color: #7b1fa2;
}

.log-panel-toggle {
  font-size: 22rpx;
  color: #bbb;
}

.log-panel-body {
  display: flex;
  flex-direction: column;
}

.log-filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #f0f3f9;
  background: #fafbfd;
  gap: 12rpx;
}

.log-filter-tabs {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  flex: 1;
}

.log-filter-tab {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #bbb;
  background: #f2f4f8;
  border: 1rpx solid transparent;
}

.log-tab-active       { color: #333;     background: #e8ecf5; border-color: #c8d0e4; }
.log-tab-active-send  { color: #2e7d32;  background: rgba(46,125,50,0.08);   border-color: rgba(46,125,50,0.25); }
.log-tab-active-recv  { color: #1565c0;  background: rgba(25,118,210,0.08);  border-color: rgba(25,118,210,0.25); }
.log-tab-active-info  { color: #e65100;  background: rgba(230,81,0,0.08);    border-color: rgba(230,81,0,0.25); }
.log-tab-active-error { color: #c62828;  background: rgba(198,40,40,0.08);   border-color: rgba(198,40,40,0.25); }

.log-action { padding: 6rpx 12rpx; border-radius: 8rpx; }
.text-red   { color: #c62828; }

.log-scroll {
  height: 420rpx;
  background: #fafbfd;
}

.dlog-item {
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #f0f3f9;
  border-left: 4rpx solid transparent;
}
.dlog-item:active { opacity: 0.7; }
.dlog-item-send   { border-left-color: #43a047; background: rgba(67,160,71,0.04); }
.dlog-item-recv   { border-left-color: #1976d2; background: rgba(25,118,210,0.04); }
.dlog-item-info   { border-left-color: #f57f17; background: rgba(245,127,23,0.03); }
.dlog-item-error  { border-left-color: #e53935; background: rgba(229,57,53,0.04); }

.dlog-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.dlog-time {
  font-size: 18rpx;
  color: #bbb;
  font-family: 'Courier New', monospace;
}

.dlog-dir-badge {
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
}
.dlog-dir-badge.send  { color: #2e7d32; background: rgba(46,125,50,0.1); }
.dlog-dir-badge.recv  { color: #1565c0; background: rgba(25,118,210,0.1); }
.dlog-dir-badge.info  { color: #e65100; background: rgba(230,81,0,0.1); }
.dlog-dir-badge.error { color: #c62828; background: rgba(198,40,40,0.1); }

.dlog-data {
  font-size: 22rpx;
  color: #444;
  word-break: break-all;
  line-height: 1.6;
  display: block;
}

.log-empty {
  padding: 36rpx 24rpx;
  text-align: center;
}
